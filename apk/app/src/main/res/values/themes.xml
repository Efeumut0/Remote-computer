<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.RemoteControlApp" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorPrimaryContainer">@color/purple_primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        <item name="colorSecondary">@color/purple_secondary</item>
        <item name="colorOnSecondary">@color/surface_background</item>
        <item name="colorSecondaryContainer">@color/surface_card_alt</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorSurfaceContainer">@color/surface_card_alt</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOutline">@color/surface_outline</item>
        <item name="android:windowBackground">@drawable/bg_app_gradient</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/surface_background</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/surface_background</item>
    </style>

    <style
        name="ShapeAppearance.RemoteControlApp.HeaderLogo"
        parent="@style/ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/header_logo_corner</item>
    </style>
</resources>
